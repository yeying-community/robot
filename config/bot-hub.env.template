# ===== Bot Hub Rust Control Plane =====
# Bind address for web UI + APIs
BOT_HUB_BIND_ADDR=127.0.0.1:3900

# Optional overrides (usually keep defaults)
# BOT_HUB_REPO_ROOT=/home/administrator/code/bot_hub
# BOT_HUB_RUNTIME_DIR=/home/administrator/code/bot_hub/runtime/control-plane
# BOT_HUB_INSTANCES_ROOT=/home/administrator/code/bot_hub/runtime/instances

# Router connection
ROUTER_BASE_URL=https://test-router.yeying.pub/v1
ROUTER_API_KEY=

# Model config (default model can be changed in UI or API)
BOT_HUB_DEFAULT_MODEL=gpt-5.3-codex
BOT_HUB_MODEL_ALLOWLIST=gpt-5.3-codex,gpt-5.1-mini

# Wallet session TTL (seconds)
BOT_HUB_SESSION_TTL_SECONDS=86400

# Per-instance OpenClaw gateway port allocation range
BOT_HUB_INSTANCE_PORT_START=18800
BOT_HUB_INSTANCE_PORT_END=18999

# API security tokens
BOT_HUB_ADMIN_TOKEN=change-me-admin-token
BOT_HUB_INTERNAL_TOKEN=change-me-internal-token

# Optional command prefix for launching openclaw (useful when outbound traffic must go through local proxy)
# Example: BOT_HUB_OPENCLAW_PREFIX=proxychains4 -q
BOT_HUB_OPENCLAW_PREFIX=""

# Copy to `.env.local` before local development.
PORT=3000
DD_BOT_NAME=Yeying DD Bot
LOG_LEVEL=info

# Runtime paths
KB_DOCS_DIR=docs_source
DD_POLICY_PATH=config/policy.example.json

# Optional DingTalk integration
# Recommended for real DingTalk access (Stream Mode): fill client id / secret from the DingTalk app.
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
# Only needed if you later use HTTP callback mode with request signing.
DINGTALK_SIGNING_SECRET=

# Optional model / router integration
ROUTER_BASE_URL=https://test-router.yeying.pub/v1
ROUTER_MODEL=gpt-5.3-codex
ROUTER_API_KEY=

# Optional Alibaba DashScope fallback model (OpenAI-compatible API)
# Official compatible endpoint: https://dashscope.aliyuncs.com/compatible-mode/v1
# Recommended coding fallback model can be `qwen3-coder-plus`; change if your account uses another model.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-coder-plus
DASHSCOPE_API_KEY=

# Optional downstream systems
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
COMPANY_WIKI_BASE_URL=
COMPANY_WIKI_TOKEN=

# Optional real GitHub issue integration
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# Optional real DingTalk calendar integration
DINGTALK_CALENDAR_DEFAULT_USER_ID=
DINGTALK_CALENDAR_DEFAULT_ID=primary
DINGTALK_CALENDAR_TIMEZONE=Asia/Shanghai
